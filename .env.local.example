# App model access (OpenAI-compatible). Free via GitHub Models.
# Named MODEL_* on purpose so a system-wide OPENAI_API_KEY cannot shadow it.
# Create a GitHub fine-grained token with the "Models: read" permission,
# then copy this file to .env.local and fill in the token below.
MODEL_API_KEY=
MODEL_BASE_URL=https://models.github.ai/inference
# Optional model id override (defaults to openai/gpt-5)
# MODEL_ID=openai/gpt-5
